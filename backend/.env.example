# ========= GROQ API ==========
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ========= AZURE STORAGE ==========
# Get from Azure Portal > Storage Account > Access Keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT_NAME;AccountKey=YOUR_ACCOUNT_KEY;EndpointSuffix=core.windows.net
AZURE_CONTAINER_NAME=resumes
# Generate SAS URL from Azure Portal
AZURE_SAS_TOKEN=sv=2024-01-01&ss=bfqt&srt=sco&sp=rwdlacupitfx&se=2026-12-31T23:59:59Z&st=2026-01-01T00:00:00Z&spr=https&sig=YOUR_SAS_SIGNATURE

# ========= SALESFORCE ==========
SF_USERNAME=your_salesforce_username@example.com
SF_PASSWORD=your_salesforce_password
SF_SECURITY_TOKEN=your_salesforce_security_token
SF_DOMAIN=login

# ========= MICROSOFT OAUTH ==========
# Get from Azure AD > App registrations
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=common

# ========= URLs ==========
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ========= DOMAIN RESTRICTION ==========
# Only users with this email domain can login
ALLOWED_EMAIL_DOMAIN=aspect.co.uk
